{
  "expo": {
    "name": "YogAI",
    "slug": "yogai",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "yogai",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#2D8B5E",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yogai.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2D8B5E"
      },
      "package": "com.yogai.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-splash-screen",
      "expo-web-browser"
    ]
  }
}
